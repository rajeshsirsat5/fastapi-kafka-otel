# ── App ───────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
LOG_LEVEL=INFO

# ── OpenTelemetry zero-code configuration ─────────────────────────────────────
# These env vars are read by opentelemetry-instrument at startup.
# No Python code needed — just set the vars and run with the agent.

# Service identity (shows up in every trace, metric, and log in your backend)
OTEL_SERVICE_NAME=fastapi-kafka-service
OTEL_SERVICE_VERSION=1.0.0
OTEL_DEPLOYMENT_ENVIRONMENT=local

# Where to send all signals (OTel Collector HTTP endpoint)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Enable all three signals
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp

# Enable logs auto-instrumentation (injects trace_id + span_id into every log record)
OTEL_PYTHON_LOGGING_AUTO_INSTRUMENTATION_ENABLED=true

# Metrics export interval (milliseconds)
OTEL_METRIC_EXPORT_INTERVAL=15000

# Trace sampling — record 100% of traces (lower in production, e.g. 0.1 = 10%)
OTEL_TRACES_SAMPLER=always_on
